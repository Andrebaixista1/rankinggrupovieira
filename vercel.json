{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "env": {
    "UPSTREAM_API_BASE": "https://app.apivieiracred.com.br/webhook/ranking",
    "UPSTREAM_API_BASE_FALLBACK": "https://app.apivieiracred.com.br/webhook/ranking"
  },
  "rewrites": [
    { "source": "/api/ranking", "destination": "/api/ranking.js" },
    { "source": "/api/worldcup-games", "destination": "/api/worldcup-games.js" },
    { "source": "/api/worldcup-stadiums", "destination": "/api/worldcup-stadiums.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
